NODE_ENV=development
PORT=3000

# MySQL via phpMyAdmin
DATABASE_URL="mysql://root:password@localhost:3306/timeline_db"

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Encryption for Line credentials stored in DB
ENCRYPTION_KEY=change_me_exactly_32_characters__

# CORS Origins
CORS_ADMIN_URL=http://localhost:5173
CORS_SUPERADMIN_URL=http://localhost:5174
CORS_EMPLOYEE_URL=http://localhost:5175
