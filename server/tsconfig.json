{
  "compilerOptions": {
    "target":          "ES2022",
    "module":          "commonjs",
    "lib":             ["ES2022"],
    "outDir":          "./dist",
    "rootDir":         "./src",
    "strict":          false,
    "esModuleInterop": true,
    "skipLibCheck":    true,
    "resolveJsonModule": true,
    "noEmitOnError":   false
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}
