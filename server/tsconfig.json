{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "commonjs",
    "lib":               ["ES2022"],
    "outDir":            "./dist",
    "rootDir":           "./src",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "baseUrl":           ".",
    "paths":             { "@/*": ["src/*"] }
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}
