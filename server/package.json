{
  "name": "server",
  "version": "1.0.0",
  "scripts": {
    "dev":          "tsx watch src/app.ts",
    "build":        "tsc",
    "start":        "node dist/app.js",
    "test":         "vitest",
    "db:migrate":   "prisma migrate dev",
    "db:generate":  "prisma generate",
    "db:studio":    "prisma studio",
    "db:seed":      "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors":       "^9.0.0",
    "@fastify/jwt":        "^8.0.0",
    "@fastify/multipart":  "^8.0.0",
    "@prisma/client":      "^5.0.0",
    "fastify":             "^4.28.0",
    "zod":                 "^3.23.0",
    "dayjs":               "^1.11.0",
    "axios":               "^1.7.0",
    "bcryptjs":            "^2.4.3",
    "dotenv":              "^16.1.4"
  },
  "devDependencies": {
    "@types/node":       "^20.0.0",
    "@types/bcryptjs":   "^2.4.6",
    "prisma":            "^5.0.0",
    "tsx":               "^4.0.0",
    "typescript":        "^5.0.0",
    "vitest":            "^1.6.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
