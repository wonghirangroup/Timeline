# Environment example for TimeLine monorepo
# Copy to .env and fill values per service (server, admin, superadmin, employee)

# Database (MySQL) - example DSN format for Prisma
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://timeline_user:password@db:3306/timeline

# JWT
JWT_SECRET=your_jwt_secret_here

# Fastify JWT secret (used by server)
JWT_ACCESS_SECRET=your_jwt_access_secret_here

# LINE channel credentials (per-tenant stored in DB in production)
LINE_CHANNEL_ID=LINE_CHANNEL_ID_PLACEHOLDER
LINE_CHANNEL_SECRET=LINE_CHANNEL_SECRET_PLACEHOLDER

# Server
NODE_ENV=development
PORT=3000

# Prisma
PRISMA_SCHEMA_PATH=./prisma/schema.prisma

# Optional: external services
REDIS_URL=redis://redis:6379

# Notes:
# - Do NOT commit real secrets. Use secret manager for production.
# - Per-tenant LINE credentials should be stored in DB encrypted, not in env.
