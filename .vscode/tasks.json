{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "📋 Log View",
      "type": "shell",
      "command": "node scripts/log-view.js && code brain/_LOG_VIEW.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "📋 Log View (reload)",
      "type": "shell",
      "command": "node scripts/log-view.js",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
